# --- AI-провайдер интерпретаций ---
# groq | anthropic | gigachat. Для теста из РФ — groq.
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Anthropic (для продакшена)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Лимиты AI-запросов в месяц ---
FREE_QUESTIONS_PER_MONTH=3
PLUS_QUESTIONS_PER_MONTH=10

# --- ЮKassa ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Секрет в URL webhook: .../yookassa-webhook?secret=ЗНАЧЕНИЕ
YOOKASSA_WEBHOOK_SECRET=
# Строгая проверка IP-источника webhook (true/false)
YOOKASSA_VERIFY_IP=false

# --- Telegram авторизация ---
# Токен бота из BotFather (для проверки подписи initData).
TELEGRAM_BOT_TOKEN=
# JWT-секрет проекта Supabase (Settings → JWT → Legacy JWT Secret). Нужен для выпуска и проверки токенов.
# Имя НЕ может начинаться с SUPABASE_ (запрещено платформой), поэтому APP_JWT_SECRET.
APP_JWT_SECRET=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Расчёт карты (Swiss Ephemeris) ---
CHART_CALC_URL=
CHART_CALC_TOKEN=

# --- Прочее ---
APP_ORIGIN=https://begemot-m.github.io/astro-mini-app/
CRON_SECRET=
